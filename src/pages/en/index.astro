---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CryptoGame from "../../components/CryptoGame.astro";
import WeeklyNews from "../../components/WeeklyNews.astro";
---

<BaseLayout
  title="AXSetrakb - Crypto Asset Tracking & Alternative Investment Analytics"
  description="Track cryptocurrency portfolios, manage alternative investments, monitor DeFi positions, and secure digital assets with advanced blockchain analytics tools."
  lang="en"
>
  <Fragment slot="logo">AXSetrakb</Fragment>
  <Fragment slot="footer-name">AXSetrakb</Fragment>

  <!-- HERO -->
  <section class="ax-hero">
    <div class="ax-hero-bg"></div>
    <div class="ax-hero-grid"></div>
    <div class="ax-hero-content">
      <div class="ax-pill">
        <span class="ax-pulse"></span>
        <span>Live Market Data</span>
      </div>
      <h1 class="ax-title">Crypto Asset<br/><span class="ax-gradient-text">Tracking & Analytics</span></h1>
      <p class="ax-lead">Monitor portfolios, track DeFi positions, analyze on-chain data, and secure your digital assets — all in one platform.</p>
      <div class="ax-hero-stats">
        <div class="ax-stat">
          <span class="ax-stat-value">500+</span>
          <span class="ax-stat-label">Tokens Tracked</span>
        </div>
        <div class="ax-stat-divider"></div>
        <div class="ax-stat">
          <span class="ax-stat-value">24/7</span>
          <span class="ax-stat-label">Live Monitoring</span>
        </div>
        <div class="ax-stat-divider"></div>
        <div class="ax-stat">
          <span class="ax-stat-value">Multi</span>
          <span class="ax-stat-label">Chain Support</span>
        </div>
      </div>
    </div>
  </section>

  <div class="ax-ad-slot">Ad Space</div>

  <CryptoGame lang="en" />

  <!-- SERVICES -->
  <section class="ax-section">
    <div class="ax-container">
      <h2 class="ax-section-title">Platform <span class="ax-gradient-text">Features</span></h2>
      <p class="ax-section-sub">Institutional-grade tools for tracking, analyzing, and securing your digital wealth.</p>

      <div class="ax-grid">
        <article class="ax-card">
          <div class="ax-card-icon">📊</div>
          <h3>Crypto Asset Tracking</h3>
          <p>Monitor your entire cryptocurrency portfolio across wallets and exchanges in real time. Track Bitcoin, Ethereum, altcoins, and tokens with live price feeds.</p>
          <div class="ax-card-tag">Real-Time</div>
        </article>
        <article class="ax-card">
          <div class="ax-card-icon">💼</div>
          <h3>Portfolio Management</h3>
          <p>Consolidate traditional and digital assets in a single dashboard. Rebalance allocations, set alerts, and visualize your net worth across all asset classes.</p>
          <div class="ax-card-tag">Multi-Asset</div>
        </article>
        <article class="ax-card">
          <div class="ax-card-icon">🏦</div>
          <h3>Alternative Investments</h3>
          <p>Explore tokenized real estate, commodities, private equity, and NFT collectibles. Evaluate risk-adjusted returns and diversify beyond conventional markets.</p>
          <div class="ax-card-tag">Diversified</div>
        </article>
        <article class="ax-card">
          <div class="ax-card-icon">⛓️</div>
          <h3>DeFi & Blockchain</h3>
          <p>Track yield farming positions, liquidity pools, staking rewards, and lending protocols. Stay informed on smart contract audits and emerging DeFi opportunities.</p>
          <div class="ax-card-tag">On-Chain</div>
        </article>
        <article class="ax-card">
          <div class="ax-card-icon">🔒</div>
          <h3>Digital Asset Security</h3>
          <p>Best practices for securing holdings with hardware wallets, multi-signature setups, and custody solutions. Protect against hacks, scams, and key loss.</p>
          <div class="ax-card-tag">Security</div>
        </article>
        <article class="ax-card">
          <div class="ax-card-icon">🤖</div>
          <h3>AI-Powered Analytics</h3>
          <p>Advanced charting, on-chain analysis, tax reporting tools, and AI-powered market insights. Make data-driven decisions with institutional-grade analytics.</p>
          <div class="ax-card-tag">AI Insights</div>
        </article>
      </div>
    </div>
  </section>

  <div class="ax-ad-slot">Ad Space</div>

  <!-- CTA -->
  <section class="ax-cta">
    <div class="ax-cta-bg"></div>
    <div class="ax-container ax-cta-content">
      <h2>Ready to take control of your<br/><span class="ax-gradient-text">digital assets?</span></h2>
      <p>Join thousands of investors using AXSetrakb to track, analyze, and secure their crypto portfolios.</p>
      <a href="mailto:info@axsetrakb.info" class="ax-btn">Get Started</a>
    </div>
  </section>

  <div class="ax-ad-slot">Ad Space</div>

  <div class="ax-ad-slot">Ad Space</div>

  <WeeklyNews lang="en" />

  <div class="ax-ad-slot">Ad Space</div>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300..800&display=swap');
</style>

<style>
  :root {
    --ax-bg: #0a0b0f;
    --ax-surface: rgba(255,255,255,.04);
    --ax-border: rgba(255,255,255,.08);
    --ax-text: rgba(255,255,255,.85);
    --ax-muted: rgba(255,255,255,.5);
    --ax-cyan: #00f0ff;
    --ax-green: #00ff88;
    --ax-purple: #8b5cf6;
  }

  /* HERO */
  .ax-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }
  .ax-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(800px 500px at 30% 20%, rgba(0,240,255,.12), transparent 60%),
      radial-gradient(600px 400px at 70% 60%, rgba(139,92,246,.1), transparent 60%),
      radial-gradient(500px 300px at 50% 90%, rgba(0,255,136,.08), transparent 50%),
      var(--ax-bg);
  }
  .ax-hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 30%, transparent 100%);
  }
  .ax-hero-content {
    position: relative;
    max-width: 1140px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .ax-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,240,255,.08);
    border: 1px solid rgba(0,240,255,.2);
    border-radius: 999px;
    padding: 8px 16px;
    font-size: .8rem;
    color: var(--ax-cyan);
    margin-bottom: 24px;
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .ax-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--ax-green);
    box-shadow: 0 0 0 3px rgba(0,255,136,.2);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(0,255,136,.2); }
    50% { box-shadow: 0 0 0 8px rgba(0,255,136,.05); }
  }

  .ax-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
    font-family: 'Inter', sans-serif;
    letter-spacing: -.02em;
  }
  @media(max-width:640px) { .ax-title { font-size: 2.2rem; } }

  .ax-gradient-text {
    background: linear-gradient(135deg, var(--ax-cyan), var(--ax-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ax-lead {
    font-size: 1.15rem;
    color: var(--ax-muted);
    max-width: 50ch;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .ax-hero-stats {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }
  .ax-stat { text-align: center; }
  .ax-stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 800;
    color: #fff;
  }
  .ax-stat-label {
    font-size: .75rem;
    color: var(--ax-muted);
    text-transform: uppercase;
    letter-spacing: .06em;
  }
  .ax-stat-divider {
    width: 1px;
    height: 40px;
    background: var(--ax-border);
  }

  /* SECTIONS */
  .ax-section {
    background: var(--ax-bg);
    padding: 80px 0;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }
  .ax-container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .ax-section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .ax-section-sub {
    color: var(--ax-muted);
    margin-bottom: 40px;
    font-size: 1.05rem;
  }

  /* CARD GRID */
  .ax-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media(max-width:900px) { .ax-grid { grid-template-columns: repeat(2, 1fr); } }
  @media(max-width:600px) { .ax-grid { grid-template-columns: 1fr; } }

  .ax-card {
    background: var(--ax-surface);
    border: 1px solid var(--ax-border);
    border-radius: 16px;
    padding: 28px;
    transition: all .3s ease;
    position: relative;
    overflow: hidden;
  }
  .ax-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ax-cyan), var(--ax-green));
    opacity: 0;
    transition: opacity .3s;
  }
  .ax-card:hover {
    border-color: rgba(0,240,255,.2);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,.4);
  }
  .ax-card:hover::before { opacity: 1; }

  .ax-card-icon {
    font-size: 2rem;
    margin-bottom: 16px;
    width: 52px; height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,240,255,.06);
    border: 1px solid rgba(0,240,255,.1);
    border-radius: 14px;
  }
  .ax-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #fff;
  }
  .ax-card p {
    color: var(--ax-muted);
    font-size: .9rem;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .ax-card-tag {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--ax-cyan);
    background: rgba(0,240,255,.08);
    border: 1px solid rgba(0,240,255,.15);
    padding: 4px 10px;
    border-radius: 6px;
  }

  /* CTA */
  .ax-cta {
    position: relative;
    padding: 80px 0;
    text-align: center;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }
  .ax-cta-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(600px 300px at 50% 50%, rgba(0,240,255,.1), transparent 60%),
      var(--ax-bg);
  }
  .ax-cta-content {
    position: relative;
  }
  .ax-cta h2 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  .ax-cta p {
    color: var(--ax-muted);
    margin-bottom: 28px;
    font-size: 1.05rem;
  }
  .ax-btn {
    display: inline-block;
    padding: 14px 32px;
    background: linear-gradient(135deg, var(--ax-cyan), var(--ax-green));
    color: #0a0b0f;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 12px;
    text-decoration: none;
    transition: all .3s;
    box-shadow: 0 8px 30px rgba(0,240,255,.2);
  }
  .ax-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,240,255,.3);
    text-decoration: none;
  }

  /* AD SLOT */
  .ax-ad-slot {
    background: rgba(255,255,255,.02);
    border: 1px dashed rgba(255,255,255,.08);
    padding: 20px;
    text-align: center;
    margin: 0;
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,.2);
    font-size: .8rem;
    font-family: 'Inter', sans-serif;
  }
</style>
